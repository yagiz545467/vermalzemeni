{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "description": "Sipari\u015f numaras\u0131"
    },
    "product": {
      "type": "string",
      "enum": [
        "full-paket",
        "ozel-reels",
