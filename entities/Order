      "type": "number",
      "description": "\u00dcr\u00fcn fiyat\u0131"
    },
    "early_delivery": {
      "type": "boolean",
      "default": false,
      "description": "Erken teslimat"
    },
    "recipient_type": {
      "type": "string",
