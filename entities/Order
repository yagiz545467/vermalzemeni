    "contact_info": {
      "type": "string",
      "description": "\u0130leti\u015fim bilgisi"
    },
    "status": {
      "type": "string",
      "enum": [
        "odeme-bekleniyor",
        "sirada",
        "hazirlaniyor",
        "teslim-edildi",
        "iptal"
      ],
      "default": "odeme-bekleniyor",
      "description": "Sipari\u015f durumu"
